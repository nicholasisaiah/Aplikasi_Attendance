# ============================================
# ENVIRONMENT VARIABLES — Admin Web (EduAttend)
# ============================================

# --- Frontend (public, bundled into browser JS) ---
VITE_SUPABASE_URL=https://your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-side ONLY (Vercel Serverless Functions) ---
# ⚠️ JANGAN gunakan prefix VITE_ untuk key ini!
# ⚠️ JANGAN commit key asli ke Git!
# Key ini hanya ditambahkan di Vercel Dashboard → Settings → Environment Variables
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
